{
  "name": "sme-insightx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @sme-insightx/server dev",
    "dev:client": "pnpm --filter @sme-insightx/client dev",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:shared": "pnpm --filter @sme-insightx/shared build",
    "build:server": "pnpm --filter @sme-insightx/server build",
    "build:client": "pnpm --filter @sme-insightx/client build",
    "build": "pnpm build:shared && pnpm build:server && pnpm build:client",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @sme-insightx/server db:generate",
    "db:migrate": "pnpm --filter @sme-insightx/server db:migrate",
    "db:push": "pnpm --filter @sme-insightx/server db:push",
    "db:studio": "pnpm --filter @sme-insightx/server db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
